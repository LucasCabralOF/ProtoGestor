enum AppointmentStatus {
  scheduled
  done
  canceled
}

model Appointment {
  id     String            @id @default(cuid())
  orgId  String
  status AppointmentStatus @default(scheduled)

  serviceOrderId String?
  startsAt       DateTime
  endsAt         DateTime

  employeeId   String? // Contact (funcionário)
  locationText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  employee     Contact?      @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([orgId, startsAt])
  @@index([orgId, status])
  @@map("appointment")
}

model CalendarBlock {
  id       String   @id @default(cuid())
  orgId    String
  startsAt DateTime
  endsAt   DateTime
  reason   String?

  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, startsAt])
  @@map("calendar_block")
}
