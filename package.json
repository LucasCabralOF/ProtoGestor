{
  "name": "proto",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "prisma generate && next build",
    "start": "next start --port 3001",
    "check": "tsc --noEmit && biome check",
    "check:ci": "tsc --noEmit && biome ci",
    "check:fix": "biome check --write",
    "check:fix:unsafe": "biome check --write --unsafe",
    "check:locales": "npx --yes @lingual/i18n-check@latest -s en -l src/locales",
    "db:generate": "prisma format && prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:migrate:status": "prisma migrate status",
    "db:push": "prisma db push --accept-data-loss",
    "db:reset": "npm run db:generate && prisma db push --force-reset && prisma db seed",
    "db:studio": "prisma studio --port 5555",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "1.3.0",
    "@prisma/adapter-pg": "7.3.0",
    "@prisma/client": "7.3.0",
    "antd": "6.3.0",
    "better-auth": "^1.4.18",
    "date-fns": "4.1.0",
    "es-toolkit": "1.44.0",
    "next": "^16.1.6",
    "next-intl": "4.8.0",
    "next-safe-action": "8.0.0",
    "pg": "^8.18.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "5.5.0",
    "zod": "4.3.0",
    "zustand": "5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@tailwindcss/postcss": "^4.2.0",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^20.19.0",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "dotenv": "17.2.0",
    "jsdom": "28.0.0",
    "prisma": "7.3.0",
    "tailwindcss": "^4.2.0",
    "tsx": "4.21.0",
    "typescript": "^5.4.0",
    "vite-tsconfig-paths": "6.1.0",
    "vitest": "4.0.0"
  }
}
